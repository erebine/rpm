# Environment for erebine-eem-agent.service.
# The join key, router URL, and registration name are required for
# first-start enrollment; get a join key from the Erebine dashboard.
# XEROTIER_AGENT_JOIN_KEY=xjk_your_key_here
# XEROTIER_ROUTER_URL=https://your-router.example.com
# XEROTIER_AGENT_REGISTRATION_NAME=eem-host-01
# XEM_AGENT_LOG_LEVEL=info
